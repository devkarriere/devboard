      "title": "boardsReducer",
      "badge": "Reducer",
      "path": "src/lib/boardsReducer.ts",
      "group": "state",
      "summary": "Pure Funktion über Board[]. \"create\" erzeugt ein neues Board mit drei Default-Spalten (\"To Do\", \"In Progress\", \"Done\") und leerer Task-Liste. \"delete\" entfernt das Board mit der gegebenen ID. Wird in der BoardsPage per useReducer benutzt.",
      "sections": [],
      "subtitle": "create | delete",
      "position": {
        "x": 558,
        "y": 1012,
        "w": 220,
        "h": 78
      }
